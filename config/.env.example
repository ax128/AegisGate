# AegisGate 可调参数（复制为 .env 后编辑，重启生效；支持热重载的项会标注）
# 变量名见 README "Configuration" 章节，前缀 AEGIS_

# ─── 日志与运行 ────────────────────────────────────────────
AEGIS_LOG_LEVEL=info
# DEBUG 下是否打印完整请求正文（默认 false：只打 method/path/route/headers + body_size）
AEGIS_LOG_FULL_REQUEST_BODY=false
AEGIS_ENV=prod

# ─── 安全档位与网关 ──────────────────────────────────────────
# low: 极宽松，基本只脱敏 | medium（默认）: 宽松，仅高危+脱敏 | high: 全量检测
AEGIS_SECURITY_LEVEL=medium
# 命中强制命令规则后直接拦截（不依赖 security_level 阈值）
AEGIS_STRICT_COMMAND_BLOCK_ENABLED=false
# 网关密钥从 config/aegis_gateway.key 自动加载；首次启动自动生成（chmod 600）
# 查看密钥：cat config/aegis_gateway.key
# Docker/CI 可用此变量覆盖文件：AEGIS_GATEWAY_KEY=<your-key>
AEGIS_DEFAULT_POLICY=default
# 逗号分隔受信任反向代理 IP（支持 CIDR 如 172.16.0.0/12）；仅这些 IP 的 XFF 会被信任。
# 留空 = 仅信任直连 IP（最安全默认）。
AEGIS_TRUSTED_PROXY_IPS=
# 仅允许本机访问（loopback）；Docker 部署需设为 false（compose 已默认）
AEGIS_ENFORCE_LOOPBACK_ONLY=true
# 留空则自动生成 Fernet 密钥到 config/aegis_fernet.key
# AEGIS_ENCRYPTION_KEY=
# 风险评分阈值（0-1），越低越容易触发拦截
AEGIS_RISK_SCORE_THRESHOLD=0.7

# ─── HMAC 请求签名（生产环境强烈建议启用）─────────────────────────
# 启用后，所有请求必须携带 HMAC-SHA256 签名；可有效防止重放攻击和未授权调用。
# 生产环境（AEGIS_ENV=prod）未启用时启动日志会显示安全警告。
# AEGIS_ENABLE_REQUEST_HMAC_AUTH=false
# 签名密钥（启用后必须设置，建议至少 32 字节随机值）
# AEGIS_REQUEST_HMAC_SECRET=<your-strong-secret-here>
# AEGIS_REQUEST_SIGNATURE_HEADER=x-aegis-signature
# AEGIS_REQUEST_TIMESTAMP_HEADER=x-aegis-timestamp
# AEGIS_REQUEST_NONCE_HEADER=x-aegis-nonce
# AEGIS_REQUEST_REPLAY_WINDOW_SECONDS=300

# ─── UI 会话 ──────────────────────────────────────────────
AEGIS_LOCAL_UI_SESSION_TTL_SECONDS=43200
AEGIS_LOCAL_UI_LOGIN_RATE_LIMIT_PER_MINUTE=10
AEGIS_LOCAL_UI_SECURE_COOKIE=true
AEGIS_LOCAL_UI_ALLOW_INTERNAL_NETWORK=false

# ─── 上游与限流 ──────────────────────────────────────────────
# v1 默认上游（设置后仅 localhost/内网客户端可直连 /v1/...；公网调用请改用 token 路径）
# AEGIS_UPSTREAM_BASE_URL=http://localhost:8317/v1
AEGIS_UPSTREAM_TIMEOUT_SECONDS=600
AEGIS_UPSTREAM_MAX_CONNECTIONS=300
AEGIS_UPSTREAM_MAX_KEEPALIVE_CONNECTIONS=100
# 流式请求在首包前失败时的重试次数（仅在尚未向客户端发送任何字节时触发）。
# 默认 0（关闭）；开启后可能触发上游重复执行，建议仅在可接受幂等重试的场景启用。
AEGIS_STREAM_BOOTSTRAP_RETRIES=0
AEGIS_ENABLE_THREAD_OFFLOAD=false
AEGIS_FILTER_PIPELINE_TIMEOUT_S=90
# 请求过滤管道超时动作："block"（安全默认）或 "pass"（兼容旧行为）
AEGIS_REQUEST_PIPELINE_TIMEOUT_ACTION=block
AEGIS_MAX_REQUEST_BODY_BYTES=12000000
# multipart/form-data 请求体上限（如 OpenAI /v1/images/edits、/v1/images/variations、/v1/files）。
# OpenAI 图像编辑 mask 要求 image+mask <50MB；此处默认留出一定 buffer。
AEGIS_MAX_MULTIPART_BODY_BYTES=60000000
AEGIS_MAX_MESSAGES_COUNT=500
AEGIS_MAX_CONTENT_LENGTH_PER_MESSAGE=250000
AEGIS_MAX_PENDING_PAYLOAD_BYTES=1200000
AEGIS_MAX_RESPONSE_LENGTH=2000000
# 管理端点速率限制：每分钟每 IP 最大请求数
AEGIS_ADMIN_RATE_LIMIT_PER_MINUTE=30

# ─── 端口路由与 Docker 上游 ────────────────────────────────────
# 本地端口自动路由：token 为纯数字端口时自动转发到 host.docker.internal:{port}/v1
# Docker 部署默认开启（compose 已配置），裸机部署需手动开启
AEGIS_ENABLE_LOCAL_PORT_ROUTING=false
# 是否允许公网/非内网客户端使用纯数字 token（1024-65535）。
# 默认 false：数字 token 可预测，建议仅内网使用；公网请改用随机 token（register 或 gw_tokens.json 映射）。
AEGIS_ALLOW_PUBLIC_NUMERIC_TOKENS=false
# 裸机部署改为 127.0.0.1
AEGIS_LOCAL_PORT_ROUTING_HOST=host.docker.internal
# 是否允许公网/非内网客户端使用 token__passthrough 跳过全部安全过滤器。
# 默认 false：passthrough 会禁用所有过滤器，建议仅内网调试使用。
AEGIS_ALLOW_PUBLIC_PASSTHROUGH_MODE=false
# compat 端口路由允许端口白名单（claude-to-gpt/<port>... 等）。逗号分隔。
# 留空 = 禁用 compat 端口路由（安全默认，fail-closed）。
# 示例：AEGIS_COMPAT_ALLOWED_PORTS=8317,8080
AEGIS_COMPAT_ALLOWED_PORTS=
# 是否自动注入内置 compat token（例如 "claude-to-gpt"）。默认关闭；建议仅本机/内网开发使用。
AEGIS_ENABLE_BUILTIN_COMPAT_TOKENS=false
# Docker 上游自动注入：启动时自动注册 token → Docker 服务名映射（同名映射优先级高于端口路由）
# 格式：token:service[:port]，逗号分隔。port 省略时默认等于 token。
# 示例：8317:cli-proxy-api,8080:sub2api,3000:aiclient2api
# 改名/改端口/新增上游：直接修改此变量，重启网关即生效。
# AEGIS_DOCKER_UPSTREAMS=8317:cli-proxy-api,8080:sub2api,3000:aiclient2api

# Relay 兼容端点（默认关闭；启用后暴露 POST /relay/generate，且调用方仍需提供内部 x-upstream-base/gateway-key 头）
# AEGIS_ENABLE_RELAY_ENDPOINT=false

# ─── v2 代理（HTTP/HTTPS 通用转发）──────────────────────────────
AEGIS_ENABLE_V2_PROXY=true
AEGIS_V2_ENABLE_REQUEST_REDACTION=true
AEGIS_V2_ENABLE_RESPONSE_COMMAND_FILTER=true
# true: 启用最小误拦模式（仅协议层高危 HTTP 报文特征：走私/响应拆分/报文混淆）
AEGIS_V2_RESPONSE_FILTER_OBVIOUS_ONLY=true
# 留空 = 拒绝所有外部目标（安全默认，fail-closed）；生产必须显式配置可信域名
# 逗号分隔；支持 example.com / .example.com / *.example.com
# 示例：AEGIS_V2_TARGET_ALLOWLIST=api.openai.com,.anthropic.com
AEGIS_V2_TARGET_ALLOWLIST=
# 逗号分隔；支持 example.com / .example.com / *.example.com
AEGIS_V2_RESPONSE_FILTER_BYPASS_HOSTS=
AEGIS_V2_RESPONSE_FILTER_MAX_CHARS=200000
AEGIS_V2_SSE_FILTER_PROBE_MAX_CHARS=4000
# 阻止 v2 代理请求到内部/私有 IP（SSRF 防护）
AEGIS_V2_BLOCK_INTERNAL_TARGETS=true

# ─── 语义复核（灰区门控；调用语义服务；URL 未配置时仅灰区降级记录 semantic_service_unconfigured） ───
AEGIS_ENABLE_SEMANTIC_MODULE=true
# 仅当风险评分落在 (AEGIS_SEMANTIC_GRAY_LOW, AEGIS_SEMANTIC_GRAY_HIGH) 才触发语义复核。
# 留空时：灰区触发会记录 semantic_service_unconfigured 并降级（不做语义风险抬升，不会请求外部服务）；不会自动切回仓库内 TF-IDF 资源。
AEGIS_SEMANTIC_SERVICE_URL=
AEGIS_SEMANTIC_GRAY_LOW=0.25
AEGIS_SEMANTIC_GRAY_HIGH=0.75
AEGIS_SEMANTIC_TIMEOUT_MS=150
AEGIS_SEMANTIC_CACHE_TTL_SECONDS=300
AEGIS_SEMANTIC_CIRCUIT_FAILURE_THRESHOLD=3
AEGIS_SEMANTIC_CIRCUIT_OPEN_SECONDS=30

# ─── 过滤器开关（默认均为 true，按需关闭）──────────────────────────
# AEGIS_ENABLE_REDACTION=true
# AEGIS_ENABLE_EXACT_VALUE_REDACTION=true
# AEGIS_ENABLE_RESTORATION=true
# AEGIS_ENABLE_INJECTION_DETECTOR=true
# AEGIS_ENABLE_PRIVILEGE_GUARD=true
# AEGIS_ENABLE_ANOMALY_DETECTOR=true
# AEGIS_ENABLE_REQUEST_SANITIZER=true
# AEGIS_ENABLE_OUTPUT_SANITIZER=true
# AEGIS_ENABLE_POST_RESTORE_GUARD=true
# AEGIS_ENABLE_SYSTEM_PROMPT_GUARD=false
# AEGIS_ENABLE_UNTRUSTED_CONTENT_GUARD=true
# AEGIS_ENABLE_TOOL_CALL_GUARD=true
# AEGIS_ENABLE_RAG_POISON_GUARD=true

# ─── 存储后端 ──────────────────────────────────────────────
AEGIS_STORAGE_BACKEND=sqlite
AEGIS_SQLITE_DB_PATH=logs/aegisgate.db
# SQLite mapping_store 定期清理间隔（秒），用于删除超出 pending_data_ttl_seconds 的旧映射
AEGIS_MAPPING_PRUNE_INTERVAL_SECONDS=3600
AEGIS_AUDIT_LOG_PATH=logs/audit.jsonl
AEGIS_ENABLE_DANGEROUS_RESPONSE_LOG=false
# 实际写盘文件名会自动变为 dangerous_response_samples-YYYY-MM-DD.jsonl，并自动清理 10 天前旧文件
AEGIS_DANGEROUS_RESPONSE_LOG_PATH=logs/dangerous_response_samples.jsonl
# AEGIS_REDIS_URL=redis://127.0.0.1:6379/0
# AEGIS_POSTGRES_DSN=postgresql://<user>:<password>@127.0.0.1:5432/aegisgate
