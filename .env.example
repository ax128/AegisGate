# AegisGate environment variables (copy to .env and fill in; do not commit .env)
# Required for production — leave empty to auto-generate a secure random key on first startup.
# The generated key is persisted to config/aegis_gateway.key (chmod 600).
AEGIS_GATEWAY_KEY=

# Optional: encryption key for redaction mapping (Fernet AES-128-CBC+HMAC).
# Leave empty to auto-generate and persist to config/aegis_fernet.key.
# AEGIS_ENCRYPTION_KEY=

# Optional: upstream and limits
AEGIS_UPSTREAM_BASE_URL=https://api.openai.com
AEGIS_UPSTREAM_WHITELIST_URL_LIST=
AEGIS_UPSTREAM_TIMEOUT_SECONDS=60
AEGIS_ENABLE_THREAD_OFFLOAD=false
AEGIS_FILTER_PIPELINE_TIMEOUT_S=30
AEGIS_MAX_REQUEST_BODY_BYTES=2000000
AEGIS_MAX_MESSAGES_COUNT=100
AEGIS_MAX_CONTENT_LENGTH_PER_MESSAGE=50000
AEGIS_MAX_PENDING_PAYLOAD_BYTES=100000
AEGIS_MAX_RESPONSE_LENGTH=500000

# Optional: logging (debug = 打印完整请求 method/path/headers/body 便于调试)
AEGIS_LOG_LEVEL=info

# Optional: security
AEGIS_SECURITY_LEVEL=medium
AEGIS_ENFORCE_LOOPBACK_ONLY=true
# Comma-separated trusted reverse-proxy IPs; only these may set X-Forwarded-For.
# Empty = trust direct client IP only (safest default).
AEGIS_TRUSTED_PROXY_IPS=
AEGIS_ENABLE_REQUEST_HMAC_AUTH=false
AEGIS_REQUEST_HMAC_SECRET=
AEGIS_ENABLE_V2_PROXY=true
AEGIS_V2_ENABLE_REQUEST_REDACTION=true
AEGIS_V2_ENABLE_RESPONSE_COMMAND_FILTER=true
AEGIS_V2_RESPONSE_FILTER_MAX_CHARS=200000
# Block v2 proxy requests to internal/private IPs (SSRF protection)
AEGIS_V2_BLOCK_INTERNAL_TARGETS=true
# Request filter pipeline timeout action: "block" (safe default) or "pass" (legacy)
AEGIS_REQUEST_PIPELINE_TIMEOUT_ACTION=block
# Admin endpoint rate limit: max requests per minute per client IP
AEGIS_ADMIN_RATE_LIMIT_PER_MINUTE=30

# Optional: storage (default sqlite)
AEGIS_STORAGE_BACKEND=sqlite
# Docker 下若 logs 目录不可写可设为 /tmp/aegisgate.db
AEGIS_SQLITE_DB_PATH=logs/aegisgate.db
# 审计日志路径；空则不写文件。Docker 下可设为 /tmp/audit.jsonl
AEGIS_AUDIT_LOG_PATH=logs/audit.jsonl
# AEGIS_REDIS_URL=redis://127.0.0.1:6379/0
# AEGIS_POSTGRES_DSN=postgresql://user:pass@127.0.0.1:5432/aegisgate

# Optional: semantic module (default off)
AEGIS_ENABLE_SEMANTIC_MODULE=false
AEGIS_SEMANTIC_SERVICE_URL=
